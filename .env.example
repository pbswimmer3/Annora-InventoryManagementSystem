# Google Service Account credentials JSON (entire JSON string, or base64 encoded)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Sheet ID (from the sheet URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit)
GOOGLE_SHEET_ID=

# App password (users must enter this to access the site)
APP_PASSWORD=

# Google OAuth2 credentials for Drive photo uploads.
# Service accounts have no Drive storage quota, so we use OAuth2 with a real Google account.
# 1. Create an OAuth 2.0 Client ID in Google Cloud Console (Web Application type)
# 2. Add http://localhost:3333 as an Authorized Redirect URI
# 3. Run: node scripts/get-refresh-token.js <CLIENT_ID> <CLIENT_SECRET>
# 4. Log in and paste the refresh token below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Secret for Vercel Cron job authentication (generate any random string)
CRON_SECRET=
