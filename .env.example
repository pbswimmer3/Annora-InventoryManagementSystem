# Google Service Account credentials JSON (entire JSON string, or base64 encoded)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Sheet ID (from the sheet URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit)
GOOGLE_SHEET_ID=

# App password (users must enter this to access the site)
APP_PASSWORD=

# Google Drive folder ID for photo uploads.
# Create a folder in your Google Drive, share it with the service account email (Editor access),
# and paste the folder ID from the URL: https://drive.google.com/drive/folders/{THIS_PART}
GOOGLE_DRIVE_FOLDER_ID=

# NOTE: The service account also needs Google Drive API enabled for photo uploads.
# Go to Google Cloud Console > APIs & Services > Enable "Google Drive API".

# Secret for Vercel Cron job authentication (generate any random string)
CRON_SECRET=
